// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  
  // Blind Indexes (Deterministic hashing for O(1) lookups)
  emailHash     String?  @unique @map("email_hash")
  usernameHash  String?  @unique @map("username_hash")
  
  // Encrypted Identity Fields
  email         String   // encrypted
  username      String   // encrypted
  passwordHash  String   @map("password_hash")
  displayName   String?  @map("display_name") // encrypted
  baseCurrency  String   @default("VND") @map("base_currency")
  refreshToken  String?  @map("refresh_token") // hashed
  isEmailVerified          Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken   String?   @unique @map("email_verification_token")
  emailVerificationExpires DateTime? @map("email_verification_expires")
  resetPasswordToken       String?   @unique @map("reset_password_token")
  resetPasswordExpires     DateTime? @map("reset_password_expires")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  wallets          Wallet[]
  transactions     Transaction[]
  portfolioAssets  PortfolioAsset[]
  savingsGoals     SavingsGoal[]
  recurringItems   RecurringItem[]
  savingsDeposits  SavingsDeposit[]
  marketPreferences UserMarketPreference[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────
// WALLETS  (Ví tiền)
// ─────────────────────────────────────────────────────────
model Wallet {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  
  // Blind Index for O(1) lookups
  nameHash  String?  @map("name_hash")

  name      String                         // encrypted: "Tiền mặt", "MBBank"
  type      WalletType @default(CASH)
  balance   BigInt   @default(0)           // in base currency, stored as integer
  currency  String   @default("VND")
  color     String?
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  // Integrity Links
  savingsDeposits SavingsDeposit[]
  portfolioAssets PortfolioAsset[]

  @@map("wallets")
}

enum WalletType {
  CASH
  BANK
  E_WALLET
  CREDIT

  @@map("wallet_type")
}

// ─────────────────────────────────────────────────────────
// TRANSACTIONS  (Giao dịch — entity trung tâm)
// ─────────────────────────────────────────────────────────
model Transaction {
  id               String          @id @default(uuid())
  userId           String          @map("user_id")
  walletId         String?         @map("wallet_id")
  recurringId      String?         @map("recurring_id")
  type             TransactionType
  amount           BigInt                          // in base currency (VND)
  originalAmount   BigInt          @map("original_amount")
  originalCurrency String          @map("original_currency")
  category         String
  subCategory      String?         @map("sub_category")
  date             DateTime        @db.Date
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        Wallet?        @relation(fields: [walletId], references: [id], onDelete: SetNull)
  recurringItem RecurringItem? @relation(fields: [recurringId], references: [id], onDelete: SetNull)

  // Integrity Links
  goalId           String?         @map("goal_id")
  savingsDepositId String?         @map("savings_deposit_id")
  
  savingsGoal     SavingsGoal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)
  savingsDeposit  SavingsDeposit? @relation(fields: [savingsDepositId], references: [id], onDelete: SetNull)
  portfolioAsset  PortfolioAsset?

  @@index([userId, date(sort: Desc)])
  @@index([userId, type])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  SAVING
  INVESTMENT

  @@map("transaction_type")
}

// ─────────────────────────────────────────────────────────
// PORTFOLIO ASSETS  (Danh mục đầu tư)
// ─────────────────────────────────────────────────────────
model PortfolioAsset {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  name          String
  ticker        String?
  assetType     AssetType @default(STOCK) @map("asset_type")
  units         Decimal   @db.Decimal(18, 8)
  costBasis     BigInt    @map("cost_basis")     // per unit, in VND
  currentPrice  BigInt    @map("current_price")  // per unit, in VND
  currency      String    @default("VND")
  purchaseDate  DateTime? @map("purchase_date") @db.Date
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Integrity Links
  walletId      String?         @map("wallet_id")
  transactionId String?         @unique @map("transaction_id")
  
  wallet        Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  transaction   Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("portfolio_assets")
}

enum AssetType {
  STOCK
  CRYPTO
  REAL_ESTATE
  GOLD
  OTHER

  @@map("asset_type")
}

// ─────────────────────────────────────────────────────────
// SAVINGS GOALS  (Mục tiêu tiết kiệm)
// ─────────────────────────────────────────────────────────
model SavingsGoal {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  name          String
  targetAmount  BigInt     @map("target_amount")
  currentAmount BigInt     @default(0) @map("current_amount")
  deadline      DateTime?  @db.Date
  color         String?
  icon          String?
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Integrity Links
  transactions  Transaction[]

  @@map("savings_goals")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED

  @@map("goal_status")
}

// ─────────────────────────────────────────────────────────
// RECURRING ITEMS  (Giao dịch định kỳ)
// ─────────────────────────────────────────────────────────
model RecurringItem {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  type             TransactionType
  amount           BigInt
  originalCurrency String           @map("original_currency")
  category         String
  subCategory      String?          @map("sub_category")
  interval         RecurringInterval
  nextDate         DateTime         @map("next_date") @db.Date
  notes            String?
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("recurring_items")
}

enum RecurringInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY

  @@map("recurring_interval")
}

// ─────────────────────────────────────────────────────────
// SAVINGS DEPOSITS  (Tiết kiệm có kỳ hạn)
// ─────────────────────────────────────────────────────────
model SavingsDeposit {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")

  // Blind Index for O(1) lookups
  bankNameHash   String?  @map("bank_name_hash")

  bankName       String   @map("bank_name")      // encrypted
  depositAmount  BigInt   @map("deposit_amount")   // VND
  termMonths     Int      @map("term_months")       // kỳ hạn (tháng): 1, 3, 6, 12, 18, 24
  interestRate   Decimal  @map("interest_rate") @db.Decimal(5,2)  // % năm, ví dụ: 5.50
  depositDate    DateTime @map("deposit_date") @db.Date
  maturityDate   DateTime @map("maturity_date") @db.Date
  status         String   @default("ACTIVE")        // ACTIVE | MATURED | WITHDRAWN
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Integrity Links
  walletId       String?         @map("wallet_id")
  wallet         Wallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  transactions   Transaction[]

  @@map("savings_deposits")
}
// ─────────────────────────────────────────────────────────
// MARKET DATA  (Dữ liệu thị trường)
// ─────────────────────────────────────────────────────────
model MarketData {
  id        String         @id @default(uuid())
  type      MarketDataType
  symbol    String         // e.g., 'USD/VND', 'SJC', 'STK:VNM'
  label     String         // Friendly name: 'Đô la Mỹ', 'Vàng SJC'
  price     Decimal        @db.Decimal(18, 4)
  change    Decimal?       @db.Decimal(5, 2) // Percentage change
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([type, symbol])
  @@map("market_data")
}

enum MarketDataType {
  CURRENCY
  GOLD
  STOCK

  @@map("market_data_type")
}

model UserMarketPreference {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  symbol    String
  type      MarketDataType
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, type])
  @@map("user_market_preferences")
}
